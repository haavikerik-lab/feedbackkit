{
  "name": "@feedbackkit/react",
  "version": "0.1.0",
  "description": "Embeddable React feedback widget for feedbackkit — element picker + optional AI interview.",
  "keywords": ["feedback", "feedbackkit", "widget", "react", "ai", "embeddable"],
  "license": "MIT",
  "author": "Erik Haavik",
  "homepage": "https://github.com/haavikerik-lab/feedbackkit#readme",
  "repository": { "type": "git", "url": "git+https://github.com/haavikerik-lab/feedbackkit.git", "directory": "packages/react" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "feedbackkit-dev": "./src/index.ts",
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@feedbackkit/core": "^0.1.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vitest": "^4.1.9"
  }
}
